% Hash d'empreinte forensique (affichage monospace coloré)
\newcommand{\hash}[2]{%
    \texttt{\color{CouleurBordForensic}\small #1:\,#2}%
}

% Estampille temporelle (timestamp)
\newcommand{\timestamp}[1]{%
    \texttt{\color{CouleurSecondaire}\small[#1]}%
}

% Gravité d'incident (CVSS-like)
\newcommand{\gravite}[1]{%
    \ifthenelse{\equal{#1}{critique}}%
        {\colorbox{CouleurBordAlerte}{\color{white}\bfseries\small CRITIQUE}}{}%
    \ifthenelse{\equal{#1}{haute}}%
        {\colorbox{orange}{\color{white}\bfseries\small HAUTE}}{}%
    \ifthenelse{\equal{#1}{moyenne}}%
        {\colorbox{CouleurOr}{\color{white}\bfseries\small MOYENNE}}{}%
    \ifthenelse{\equal{#1}{basse}}%
        {\colorbox{green!60!black}{\color{white}\bfseries\small BASSE}}{}%
}

